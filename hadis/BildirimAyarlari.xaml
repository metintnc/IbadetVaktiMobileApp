<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.BildirimAyarlari"
             Title="Bildirim Ayarlari"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
    
    <Grid>

        
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Label Text="Bildirim Ayarlari"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,10,0,10"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Genel Ayarlar" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tum Bildirimleri Ac" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Namaz Vakitleri" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Imsak" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Gunes" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ogle" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ikindi" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Aksam" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Yatsi" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
