<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.BildirimAyarlari"
             Title="Bildirim Ayarlari"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header & Master Switch Area -->
        <VerticalStackLayout Grid.Row="0" Padding="20,10,20,0" Spacing="10">
            <Label Text="Bildirim Ayarlari"
                   FontSize="24"
                   FontAttributes="Bold"
                   Margin="0,10,0,5"
                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

            <Frame CornerRadius="15"
                   Padding="15"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <!-- Master Switch -->
                    <Label Text="Tum Bildirimleri Ac" 
                           VerticalOptions="Center"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Switch Grid.Column="1" 
                            x:Name="MasterSwitch"
                            Toggled="MasterSwitch_Toggled"
                            OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                            ThumbColor="White"/>
                    
                    <!-- Persistent Notification -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Surekli Bildirim (Bildirim Cubugu)" 
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Switch Grid.Row="1" Grid.Column="1" 
                            x:Name="PersistentSwitch"
                            Toggled="PersistentSwitch_Toggled"
                            OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                            ThumbColor="White"/>
                </Grid>
            </Frame>
        </VerticalStackLayout>


        <ScrollView Grid.Row="1" Padding="20,10">
            <VerticalStackLayout Spacing="15" x:Name="SettingsStack">
                
                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Namaz Vakitleri" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Imsak" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchImsak"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Gunes" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchGunes"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ogle" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchOgle"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ikindi" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchIkindi"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Aksam" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchAksam"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Yatsi" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    x:Name="SwitchYatsi"
                                    Toggled="Switch_Toggled"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
