<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.NamazHocasi"
             Title="Namaz Hocası">
    
    <Grid>
        <!-- Background Image -->
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="ayarlararkaplan.png" />
            </Image.Source>
        </Image>
        
        <!-- Overlay -->
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.85" Dark="0.60" />
            </BoxView.Opacity>
        </BoxView>
        
        <Grid RowDefinitions="Auto,*,Auto" Padding="0,10,0,10" RowSpacing="10">
            
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="20,10,20,0">
                <ImageButton Source="gerigit.svg"
                             Grid.Column="0"
                             BackgroundColor="Transparent"
                             HeightRequest="40"
                             WidthRequest="40"
                             Padding="5"
                             Clicked="OnBackButtonClicked"
                             VerticalOptions="Center"
                             HorizontalOptions="Start" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Namaz Hocası"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Label Text="Adım Adım Rehber"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Book / Carousel View -->
            <CarouselView x:Name="NamazCarousel"
                          Grid.Row="1"
                          PeekAreaInsets="0"
                          Loop="False"
                          IndicatorView="indicatorView">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="20,10,20,10"
                               CornerRadius="25"
                               HasShadow="True"
                               Padding="0"
                               BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#212121}"
                               IsClippedToBounds="True">
                            
                            <Grid RowDefinitions="Auto,*">
                                <!-- Card Header -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,20,20,10" BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#004D40}">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Emoji}" 
                                           FontSize="40" 
                                           VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                        <Label Text="{Binding Baslik}" 
                                               FontSize="20" 
                                               FontAttributes="Bold" 
                                               TextColor="{AppThemeBinding Light=#00695C, Dark=#FFFFFF}"/>
                                        <Label Text="{Binding RekatBilgisi}" 
                                               FontSize="12" 
                                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                                    </VerticalStackLayout>
                                </Grid>
                                
                                <!-- Content Steps -->
                                <ScrollView Grid.Row="1" Padding="20">
                                    <VerticalStackLayout Spacing="15" BindableLayout.ItemsSource="{Binding Adimlar}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <VerticalStackLayout Spacing="5" Margin="0,0,0,10">
                                                    <Label Text="{Binding Baslik, StringFormat='🔹 {0}'}" 
                                                           FontSize="16" 
                                                           FontAttributes="Bold" 
                                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#A5D6A7}"/>
                                                    
                                                    <Label Text="{Binding Aciklama}" 
                                                           FontSize="14" 
                                                           TextColor="{AppThemeBinding Light=#424242, Dark=#EEEEEE}"/>
                                                    
                                                    <Label Text="{Binding Dua}" 
                                                           IsVisible="{Binding Dua, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                                           FontSize="18" 
                                                           HorizontalTextAlignment="End" 
                                                           FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light=#1B5E20, Dark=#81C784}"
                                                           Margin="0,5,0,0"/>

                                                    <Label Text="{Binding Okunusu}" 
                                                           IsVisible="{Binding Okunusu, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                                           FontSize="13" 
                                                           FontAttributes="Italic" 
                                                           TextColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}"/>
                                                    
                                                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" Margin="0,5,0,0"/>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </ScrollView>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <!-- Indicators -->
            <IndicatorView x:Name="indicatorView"
                           Grid.Row="2"
                           IndicatorColor="{AppThemeBinding Light=#B2DFDB, Dark=#424242}"
                           SelectedIndicatorColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                           HorizontalOptions="Center" />
            
        </Grid>
    </Grid>
    
    <ContentPage.Resources>
        <ResourceDictionary>
             <!-- Simple converter for visibility -->
             <Style TargetType="Label" /> 
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
