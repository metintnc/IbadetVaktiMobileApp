<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.KaydedilenlerPage"
             Title="Kaydedilen Ayetler"
             BackgroundColor="#FDFBF2">
    
    <Grid RowDefinitions="Auto,*">
        <Image x:Name="BackgroundImage" 
               Aspect="AspectFill"
               Grid.RowSpan="2"
               IsVisible="False"/>
        <BoxView Grid.RowSpan="2"
                 IsVisible="True">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        <!-- Header -->
        <!-- Header Frame -->
        <Frame Grid.Row="0"
               CornerRadius="20"
               Padding="15"
               Margin="0,10,0,10"
               HasShadow="True"
               BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
               BackgroundColor="{AppThemeBinding Light=#EEFFFFFF, Dark=#AA111111}">
            <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                 <!-- Geri Butonu (Entegre) -->
                <ImageButton Grid.Column="0"
                             Source="{AppThemeBinding Light=back.png, Dark=back_white.png}" 
                             BackgroundColor="Transparent"
                             HeightRequest="30"
                             WidthRequest="30"
                             VerticalOptions="Center"
                             HorizontalOptions="Start"
                             Clicked="OnBackButtonClicked"
                             IsVisible="False"/>
                             
                <!-- Basit Geri Dönüş için Label Button -->
                 <Label Grid.Column="0"
                        Text="❮"
                        FontSize="24"
                        FontAttributes="Bold"
                        VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                        Margin="0,0,10,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonClicked"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1" 
                       Text="Kaydedilen Ayetler"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                       Margin="-30,0,0,0"/>
            </Grid>
        </Frame>

        <CollectionView x:Name="KaydedilenlerCollection" Grid.Row="1" SelectionMode="None" Margin="0,10,0,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="Henüz kaydedilmiş ayet yok." TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="15,5" 
                            Padding="20" 
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=#80FAFAFA, Dark=#80000000}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.1" Radius="5" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAyahTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}" FontSize="16">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SureName}" />
                                            <Span Text=" " />
                                            <Span Text="{Binding Number}" />
                                            <Span Text=". Ayet" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Column="1" Text="{Binding SavedDate, StringFormat='{0:dd.MM.yyyy}'}" FontSize="12" TextColor="Gray"/>
                            </Grid>
                            
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                                <Label Text="{Binding ArabicText}" FontFamily="ArabicFontFamily" FontSize="20" HorizontalTextAlignment="End"/>
                            </HorizontalStackLayout>
                            
                            <Label Text="{Binding Translation}" TextColor="{AppThemeBinding Light=#2E7D32, Dark=White}" FontSize="16" MaxLines="3" LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
