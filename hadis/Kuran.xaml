<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Kuran"
             Title="Kuran">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.85" Dark="0.55" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Label Text="Kuran-i Kerim"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,10,0,10"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>

                <Frame x:Name="SonOkunanFrame"
                       Style="{StaticResource BorderFrame}" 
                       Padding="15"
                       BackgroundColor="Transparent"
                       IsVisible="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Son Okunan"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Label x:Name="SonOkunanSureLabel"
                               Text="Bakara Suresi"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                        
                        <HorizontalStackLayout>
                            <Label x:Name="SonOkunanAyetLabel"
                                   Text="Ayet 1"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                   HorizontalOptions="StartAndExpand"/>
                            <BoxView WidthRequest="12" Opacity="0"/>
                            <Label x:Name="SonOkunanAyetYuzdeLabel"
                                   Text="."
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                   HorizontalOptions="End"/>
                        </HorizontalStackLayout>
                        
                        <Button Text="Okumaya Devam Et"
                                Clicked="OkumayaDevamEt_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#26A69A}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Sure Listesi"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <SearchBar x:Name="SearchBar"
                                   Placeholder="Sure ara..."
                                   TextChanged="SearchBar_TextChanged"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                   PlaceholderColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                   BackgroundColor="Transparent"/>
                        
                        <CollectionView x:Name="SureListesi"
                                        SelectionMode="None"
                                        HeightRequest="600">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource BorderFrame}"
                                           Padding="15"
                                           Margin="0,5"
                                           BackgroundColor="Transparent">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="SureItem_Tapped"
                                                                 CommandParameter="{Binding SureNo}"/>
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding SureNo}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                                   VerticalTextAlignment="Center"
                                                   WidthRequest="40"/>
                                            
                                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                <Label Text="{Binding Ad}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                                <Label FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding AyetSayisi}"/>
                                                            <Span Text=" Ayet - "/>
                                                            <Span Text="{Binding Inis}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>
                                            
                                            <Button Grid.Column="2"
                                                    Text="Oku"
                                                    FontSize="12"
                                                    Padding="10,5"
                                                    CornerRadius="10"
                                                    BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#26A69A}"
                                                    TextColor="White"
                                                    Clicked="SureOku_Clicked"
                                                    CommandParameter="{Binding SureNo}"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
