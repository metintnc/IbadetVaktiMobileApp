<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:hadis.Models"
             x:Class="hadis.Kuran"
             Title="Kur'an">
    
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="kuran_light.png" Dark="kuranarkaplan.png" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        
        <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="20">
            
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
                <Label Grid.Column="0" WidthRequest="40" />
                <Label Grid.Column="1"
                       Text="Kur'an-ı Kerim"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                <Label Grid.Column="2"
                       Text="⚙️"
                       FontSize="26"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Margin="0,0,5,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="MealAyarlar_Clicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Son Okunan - Sabit -->
            <Border Grid.Row="1"
                   x:Name="SonOkunanFrame"
                   StrokeShape="RoundRectangle 20"
                   Padding="20"
                   Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}"
                   IsVisible="False">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OkumayaDevamEt_Clicked"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="15">
                    <Label Text="Son Okunan"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    
                    <Label x:Name="SonOkunanSureLabel"
                           Text="Bakara Sûresi"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                    
                    <HorizontalStackLayout>
                        <Label x:Name="SonOkunanAyetLabel"
                               Text="Ayet 1"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               HorizontalOptions="StartAndExpand"/>
                        <BoxView WidthRequest="12" Opacity="0"/>
                        <Label x:Name="SonOkunanAyetYuzdeLabel"
                               Text="."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                               HorizontalOptions="End"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Kaydedilenler Butonu -->
            <Border Grid.Row="2"
                   StrokeShape="RoundRectangle 15"
                   Padding="15"
                   Margin="0,0,0,0"
                   Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="KaydedilenlerButonu_Clicked"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="Kaydedilen Ayetlerim"
                           FontSize="18"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Image Grid.Column="1"
                           Source="gerigit.svg"
                           Rotation="180"
                           HeightRequest="24"
                           WidthRequest="24"
                           VerticalOptions="Center" />
               </Grid>
            </Border>

            <!-- Sure Listesi - Frame sabit, sadece liste kayıyor -->
            <Border Grid.Row="3"
                   StrokeShape="RoundRectangle 20"
                   Padding="20"
                   Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="15">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="10,0">
                        <Label Grid.Column="0"
                               Text="Sûre Listesi"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                        
                        <Label Grid.Column="1"
                               x:Name="ScrollToBottomIcon"
                               Text="📥"
                               FontSize="24"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                               VerticalOptions="Center"
                               ToolTipProperties.Text="Aşağı Kaydır">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ScrollToBottom_Clicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    
                    <SearchBar Grid.Row="1"
                               x:Name="SearchBar"
                               Placeholder="Sûre ara..."
                               TextChanged="SearchBar_TextChanged"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               PlaceholderColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               BackgroundColor="Transparent"/>
                    
                    <CollectionView Grid.Row="2"
                                    x:Name="SureListesi"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Sure">
                                <Border StrokeShape="RoundRectangle 15"
                                       Padding="15"
                                       Margin="0,5"
                                       Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="SureItem_Tapped"
                                                             CommandParameter="{Binding SureNo}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Grid.Column="0"
                                               Text="{Binding SureNo}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                               VerticalTextAlignment="Center"
                                               WidthRequest="40"/>
                                        
                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Ad}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                            <Label FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding AyetSayisi}"/>
                                                        <Span Text=" Ayet - "/>
                                                        <Span Text="{Binding Inis}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.Footer>
                            <VerticalStackLayout Padding="0,20,0,80" Spacing="10">
                                <Button x:Name="DownloadButton"
                                        Text="İnternetsiz Kullanım İçin İndir 📥"
                                        Clicked="DownloadButton_Clicked"
                                        BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="10"
                                        HeightRequest="50"
                                        Margin="0,10"/>
                                
                                <Label x:Name="DownloadStatusLabel"
                                       Text="Kur'anı indirerek internetsiz okuyabilirsiniz (~10MB)"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                       FontSize="12"
                                       HorizontalTextAlignment="Center"/>

                                <ActivityIndicator x:Name="DownloadIndicator"
                                                   IsRunning="False"
                                                   IsVisible="False"
                                                   Color="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                                   HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </Grid>
            </Border>
            
        </Grid>

        <!-- Meal Seçimi Overlay -->
        <Grid x:Name="MealSelectionOverlay"
              IsVisible="False"
              BackgroundColor="#AA000000"
              ZIndex="999"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand">
            <Border StrokeShape="RoundRectangle 20"
                    Padding="25"
                    Margin="30"
                    VerticalOptions="Center"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Meal Seçimi"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

                    <Label x:Name="AktifMealLabel"
                           Text="Aktif: Diyanet İşleri"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" Margin="0,5"/>

                    <Button Text="Diyanet İşleri Meali"
                            Clicked="OnSelectMeal_Clicked"
                            CommandParameter="11"
                            BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <Button Text="Elmalılı Hamdi Yazır (Orijinal)"
                            Clicked="OnSelectMeal_Clicked"
                            CommandParameter="14"
                            BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <Button Text="Elmalılı Hamdi Yazır (Sadeleştirilmiş)"
                            Clicked="OnSelectMeal_Clicked"
                            CommandParameter="15"
                            BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <Button Text="Süleyman Ateş"
                            Clicked="OnSelectMeal_Clicked"
                            CommandParameter="27"
                            BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <Button Text="Bayraktar Bayraklı"
                            Clicked="OnSelectMeal_Clicked"
                            CommandParameter="8"
                            BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" Margin="0,5"/>

                    <Label Text="⚠️ Meal değiştirince önbellek temizlenir, sureler yeniden indirilir."
                           FontSize="11"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>

                    <Button Text="İptal"
                            Clicked="OnCancelMealSelection_Clicked"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                            FontAttributes="Bold"
                            CornerRadius="10"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
