<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Kuran"
             Title="Kur'an">
    
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="kuranarkaplan.png" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        
        <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="20">
            
            <!-- Header - Sabit -->
            <Label Grid.Row="0"
                   Text="Kur'an-ı Kerim"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,10,0,0"
                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

            <!-- Son Okunan - Sabit -->
            <Frame Grid.Row="1"
                   x:Name="SonOkunanFrame"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}"
                   IsVisible="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OkumayaDevamEt_Clicked"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout Spacing="15">
                    <Label Text="Son Okunan"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    
                    <Label x:Name="SonOkunanSureLabel"
                           Text="Bakara Sûresi"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                    
                    <HorizontalStackLayout>
                        <Label x:Name="SonOkunanAyetLabel"
                               Text="Ayet 1"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               HorizontalOptions="StartAndExpand"/>
                        <BoxView WidthRequest="12" Opacity="0"/>
                        <Label x:Name="SonOkunanAyetYuzdeLabel"
                               Text="."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                               HorizontalOptions="End"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Kaydedilenler Butonu -->
            <Frame Grid.Row="2"
                   CornerRadius="15"
                   Padding="15"
                   Margin="0,0,0,0"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="KaydedilenlerButonu_Clicked"/>
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="Kaydedilen Ayetlerim"
                           FontSize="18"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Image Grid.Column="1"
                           Source="gerigit.svg"
                           Rotation="180"
                           HeightRequest="24"
                           WidthRequest="24"
                           VerticalOptions="Center" />
               </Grid>
            </Frame>

            <!-- Sure Listesi - Frame sabit, sadece liste kayıyor -->
            <Frame Grid.Row="3"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="15">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="10,0">
                        <Label Grid.Column="0"
                               Text="Sûre Listesi"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                        
                        <Label Grid.Column="1"
                               x:Name="ScrollToBottomIcon"
                               Text="📥"
                               FontSize="24"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                               VerticalOptions="Center"
                               ToolTipProperties.Text="Aşağı Kaydır">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ScrollToBottom_Clicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    
                    <SearchBar Grid.Row="1"
                               x:Name="SearchBar"
                               Placeholder="Sûre ara..."
                               TextChanged="SearchBar_TextChanged"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               PlaceholderColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               BackgroundColor="Transparent"/>
                    
                    <CollectionView Grid.Row="2"
                                    x:Name="SureListesi"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="15"
                                       Padding="15"
                                       Margin="0,5"
                                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="SureItem_Tapped"
                                                             CommandParameter="{Binding SureNo}"/>
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Grid.Column="0"
                                               Text="{Binding SureNo}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                               VerticalTextAlignment="Center"
                                               WidthRequest="40"/>
                                        
                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Ad}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                            <Label FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding AyetSayisi}"/>
                                                        <Span Text=" Ayet - "/>
                                                        <Span Text="{Binding Inis}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.Footer>
                            <VerticalStackLayout Padding="0,20,0,80" Spacing="10">
                                <Button x:Name="DownloadButton"
                                        Text="İnternetsiz Kullanım İçin İndir 📥"
                                        Clicked="DownloadButton_Clicked"
                                        BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="10"
                                        HeightRequest="50"
                                        Margin="0,10"/>
                                
                                <Label x:Name="DownloadStatusLabel"
                                       Text="Kur'anı indirerek internetsiz okuyabilirsiniz (~10MB)"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                       FontSize="12"
                                       HorizontalTextAlignment="Center"/>

                                <ActivityIndicator x:Name="DownloadIndicator"
                                                   IsRunning="False"
                                                   IsVisible="False"
                                                   Color="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                                   HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </Grid>
            </Frame>
            
        </Grid>
    </Grid>
</ContentPage>
