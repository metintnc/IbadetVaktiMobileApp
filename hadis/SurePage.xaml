<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:hadis.ViewModels"
             xmlns:models="clr-namespace:hadis.Models"
             x:Class="hadis.SurePage"
             Title="{Binding SureTitle}"
             BackgroundColor="#FDFBF2">
    <Grid RowDefinitions="Auto,*">
        <Image Aspect="AspectFill"
               Grid.RowSpan="2"
               IsVisible="True">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="kuranarkaplan.webp" />
            </Image.Source>
        </Image>
        <BoxView Grid.RowSpan="2"
                 IsVisible="True">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *"
              Padding="10,15,10,10"
              Margin="0,20,0,0">
            <ImageButton Source="gerigit.svg"
                         Grid.Column="0"
                         BackgroundColor="Transparent"
                         HeightRequest="40"
                         WidthRequest="40"
                         Padding="5"
                         Clicked="OnBackButtonClicked"
                         VerticalOptions="Center"
                         HorizontalOptions="Start" />
            <HorizontalStackLayout Grid.Column="1" 
                                   Spacing="8" 
                                   HorizontalOptions="Start" 
                                   VerticalOptions="Center"
                                   Margin="5,0,0,0">
                <Label Text="{Binding SureTitle}" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="#00796B" 
                       VerticalOptions="Center" />
                <Label Text="{Binding SureTitleArabic}" 
                       FontSize="20" 
                       VerticalOptions="Center" 
                       TextColor="#81C784" />
            </HorizontalStackLayout>
        </Grid>
        <CollectionView x:Name="SureCollectionView" Grid.Row="1" ItemsSource="{Binding Ayahs}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Ayah">
                    <Border Margin="15,10" Padding="20" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=#80FAFAFA, Dark=#80000000}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.1" Radius="5" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="Auto, *" HorizontalOptions="FillAndExpand">
                                <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#E8F1F2" HorizontalOptions="Start">
                                    <Label Text="{Binding Number}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#00796B" />
                                </Border>

                                <ImageButton Grid.Column="1"
                                             HeightRequest="30"
                                             WidthRequest="30"
                                             Padding="10"
                                             HorizontalOptions="End"
                                             VerticalOptions="Center"
                                             BackgroundColor="Transparent"
                                             Clicked="OnSaveAyahClicked"
                                             CommandParameter="{Binding .}">
                                    <ImageButton.Source>
                                        <AppThemeBinding Light="kaydet.svg" Dark="kaydet_white.svg" />
                                    </ImageButton.Source>
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton" Binding="{Binding IsSaved}" Value="True">
                                            <Setter Property="Source">
                                                <Setter.Value>
                                                    <AppThemeBinding Light="kaydet_filled_white.svg" Dark="kaydet_filled_white.svg" />
                                                </Setter.Value> 
                                            </Setter>
                                            <!-- Not: Ikon içi dolu ve beyaz istendiği için her iki temada da beyaz filled kullanıyorum. 
                                                 Açık temada görünürlük sorunu olursa kural değişebilir ama istek "içi beyaz olsun" yönündeydi. 
                                                 Arka plan açık renkse beyaz görünmeyebilir? 
                                                 Kullanıcı "resmin içi beyaz olsun" dedi. 
                                                 Normal, kaydedilmemiş hali: Siyah (Light) / Beyaz (Dark)
                                                 Kaydedilmiş hali: İçi dolu Beyaz (Her ikisinde de). Light bg üstünde beyaz görünmeyebilir mi?
                                                 SurePage bg #FDFBF2 (açık krem). Beyaz ikon çok silik kalabilir.
                                                 Yine de isteğe sadık kalıp filled_white deniyorum, gerekirse filled_black yaparız.
                                                 Güvenlik için Light modda koyu bir filled ikon gerekebilir ama şimdilik isteği yapalım. -->
                                         </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>
                            <Label Text="{Binding ArabicText}"
                                   FontSize="28"
                                   HorizontalOptions="End"
                                   HorizontalTextAlignment="End"
                                   FontFamily="ArabicFontFamily"
                                   TextColor="{AppThemeBinding Light=#212121, Dark=White}" />
                            <Label Text="{Binding Translation}"
                                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=White}"
                                   FontSize="16"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding Transliteration}"
                                   FontAttributes="Italic"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=Gray, Dark=White}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{AppThemeBinding Light=#00796B, Dark=White}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>


