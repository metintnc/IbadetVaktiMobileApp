<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.WidgetAyarlari"
             Title="Widget Ayarlari"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
    
    <Grid>

        
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Label Text="Widget Ayarlari"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,10,0,10"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Widget Durumu" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Widget Etkin" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Switch Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                    ThumbColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Widget Boyutu" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <RadioButton Content="Kucuk (2x2)" 
                                     IsChecked="True"
                                     TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}">
                            <RadioButton.ControlTemplate>
                                <ControlTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Grid.Column="0"
                                                WidthRequest="22"
                                                HeightRequest="22"
                                                VerticalOptions="Center"
                                                Stroke="{AppThemeBinding Light=#80009688, Dark=#FFFFFF}"
                                                StrokeThickness="2"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 11">
                                            <Ellipse WidthRequest="12"
                                                     HeightRequest="12"
                                                     Fill="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     IsVisible="{TemplateBinding IsChecked}"/>
                                        </Border>
                                        <ContentPresenter Grid.Column="1"
                                                          VerticalOptions="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </RadioButton.ControlTemplate>
                        </RadioButton>
                        
                        <RadioButton Content="Orta (4x2)"

                                     TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}">
                            <RadioButton.ControlTemplate>
                                <ControlTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Grid.Column="0"
                                                WidthRequest="22"
                                                HeightRequest="22"
                                                VerticalOptions="Center"
                                                Stroke="{AppThemeBinding Light=#80009688, Dark=#FFFFFF}"
                                                StrokeThickness="2"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 11">
                                            <Ellipse WidthRequest="12"
                                                     HeightRequest="12"
                                                     Fill="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     IsVisible="{TemplateBinding IsChecked}"/>
                                        </Border>
                                        <ContentPresenter Grid.Column="1"
                                                          VerticalOptions="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </RadioButton.ControlTemplate>
                        </RadioButton>
                        
                        <RadioButton Content="Buyuk (4x4)"
                                     TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}">
                            <RadioButton.ControlTemplate>
                                <ControlTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Grid.Column="0"
                                                WidthRequest="22"
                                                HeightRequest="22"
                                                VerticalOptions="Center"
                                                Stroke="{AppThemeBinding Light=#80009688, Dark=#FFFFFF}"
                                                StrokeThickness="2"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 11">
                                            <Ellipse WidthRequest="12"
                                                     HeightRequest="12"
                                                     Fill="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     IsVisible="{TemplateBinding IsChecked}"/>
                                        </Border>
                                        <ContentPresenter Grid.Column="1"
                                                          VerticalOptions="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </RadioButton.ControlTemplate>
                        </RadioButton>
                    </VerticalStackLayout>
                </Frame>

                <!-- Saat & Namaz Vakti Widget -->
                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Saat &amp; Namaz Vakti Widget"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <!-- Widget Önizleme -->
                        <Frame BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                               BackgroundColor="#80000000"
                               Padding="16"
                               CornerRadius="12"
                               HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto">
                                <!-- Sol: Saat ve Tarih -->
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label Text="21:31"
                                           FontSize="42"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                    
                                    <Label Text="13 Ocak, Sal"
                                           FontSize="12"
                                           TextColor="White"
                                           Margin="0,-4,0,0"/>
                                </VerticalStackLayout>
                                
                                <!-- Sag: Namaz Vakti -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="Imsak"
                                           FontSize="12"
                                           TextColor="White"
                                           HorizontalOptions="End"/>
                                    
                                    <Label Text="3s 45d"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                        
                        <Label Text="Ana ekrana saat ve sonraki namaza kalan süreyi gösteren şeffaf widget ekler"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        
                        <Button x:Name="EkleButton"
                                Text="Ana Ekrana Ekle"
                                Clicked="EkleButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                                TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#00796B}"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="16"
                                HorizontalOptions="Fill"
                                Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
