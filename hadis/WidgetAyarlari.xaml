<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.WidgetAyarlari"
             Title="Widget Ayarlari">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.85" Dark="0.55" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Label Text="Widget Ayarlari"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,10,0,10"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>

                <Frame Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Widget Durumu" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Widget Etkin" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#212121, Dark=#E0E0E0}"/>
                            <Switch Grid.Column="1" IsToggled="True"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Widget Boyutu" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <RadioButton Content="Kucuk (2x2)" IsChecked="True"
                                     TextColor="{AppThemeBinding Light=#212121, Dark=#E0E0E0}"/>
                        <RadioButton Content="Orta (4x2)"
                                     TextColor="{AppThemeBinding Light=#212121, Dark=#E0E0E0}"/>
                        <RadioButton Content="Buyuk (4x4)"
                                     TextColor="{AppThemeBinding Light=#212121, Dark=#E0E0E0}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Saat & Namaz Vakti Widget -->
                <Frame Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Saat &amp; Namaz Vakti Widget"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <!-- Widget Önizleme -->
                        <Frame BorderColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                               BackgroundColor="#80000000"
                               Padding="16"
                               CornerRadius="12"
                               HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto">
                                <!-- Sol: Saat ve Tarih -->
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label Text="21:31"
                                           FontSize="42"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                    
                                    <Label Text="13 Ocak, Sal"
                                           FontSize="12"
                                           TextColor="White"
                                           Margin="0,-4,0,0"/>
                                </VerticalStackLayout>
                                
                                <!-- Sag: Namaz Vakti -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="Imsak"
                                           FontSize="12"
                                           TextColor="White"
                                           HorizontalOptions="End"/>
                                    
                                    <Label Text="3s 45d"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                        
                        <Label Text="Ana ekrana saat ve sonraki namaza kalan süreyi gösteren şeffaf widget ekler"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        
                        <Button x:Name="EkleButton"
                                Text="Ana Ekrana Ekle"
                                Clicked="EkleButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="16"
                                HorizontalOptions="Fill"
                                Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
