<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.ArkaplanSecim"
             Title="Arkaplan Sec">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.85" Dark="0.55" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Label Text="Arkaplan Sec"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,10,0,10"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>

                <Label Text="Arkaplanlardan birini secin ve seffaflik ayarlayin:"
                       FontSize="14"
                       Margin="0,0,0,10"
                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>

                <!-- Opacity Slider -->
                <Frame Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="OpacityLabel"
                               Text="Arkaplan Seffafligi: 30%"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Slider x:Name="OpacitySlider"
                                Minimum="0"
                                Maximum="1"
                                Value="0.3"
                                ValueChanged="OpacitySlider_ValueChanged"
                                MinimumTrackColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                MaximumTrackColor="{AppThemeBinding Light=#BDBDBD, Dark=#757575}"
                                ThumbColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Label Text="Dusuk deger: Arkaplan daha belirgin | Yuksek deger: Arkaplan daha seffaf"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Arkaplan 1 -->
                <Frame Style="{StaticResource BorderFrame}" Padding="0" BackgroundColor="Transparent" HasShadow="True">
                    <Grid>
                        <Image Source="bg_dark.jpg"
                               Aspect="AspectFill"
                               HeightRequest="150"/>
                        <BoxView Color="Black" Opacity="0.3" />
                        <Button Text="Koyu Arkaplan"
                                Clicked="KoyuArkaplan_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- Arkaplan 2 -->
                <Frame Style="{StaticResource BorderFrame}" Padding="0" BackgroundColor="Transparent" HasShadow="True">
                    <Grid>
                        <Image Source="bg_light.jpg"
                               Aspect="AspectFill"
                               HeightRequest="150"/>
                        <BoxView Color="White" Opacity="0.3" />
                        <Button Text="Acik Arkaplan"
                                Clicked="AcikArkaplan_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#212121}"
                                FontSize="18"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
