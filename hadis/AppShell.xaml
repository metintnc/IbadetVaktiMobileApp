<Shell
    x:Class="hadis.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:hadis"
    Title="hadis"
    
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#1A1A1A, Dark=#1A1A1A}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#00BCD4, Dark=#00BCD4}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#666666, Dark=#666666}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#666666, Dark=#666666}">
    
    <TabBar>
        
        <Tab Title="Vakit" Icon="vakitler.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="Pusula" Icon="kiblesekme.png"> 
            <ShellContent ContentTemplate="{DataTemplate local:kible}" />
        </Tab>
        <Tab Title="Gelisim" Icon="zikirmatik.png">
            <ShellContent ContentTemplate="{DataTemplate local:zikirmatik}" />
        </Tab>
        <Tab Title="Kesfet" Icon="kuran.png">
            <ShellContent ContentTemplate="{DataTemplate local:Kuran}" />
        </Tab>
        <Tab Title="Profil" Icon="dotnet_bot.png"> 
            <ShellContent ContentTemplate="{DataTemplate local:Ayarlar}" />
        </Tab>

    </TabBar>
    
    <ShellContent x:Name="KuranPDFPage" 
                  Route="KuranPDF"
                  ContentTemplate="{DataTemplate local:KuranPDF}"
                  IsVisible="False"/>
</Shell>
