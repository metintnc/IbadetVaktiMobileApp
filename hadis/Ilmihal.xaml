<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Ilmihal"
             Title="İlmihal">
    
    <Grid>
        <!-- Background -->
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="ayarlararkaplan.png" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.85" Dark="0.60" />
            </BoxView.Opacity>
        </BoxView>
        
        <Grid RowDefinitions="Auto,*,Auto" Padding="0,10,0,10" RowSpacing="10">
            
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="20,10,20,0">
                <ImageButton Source="gerigit.svg"
                             Grid.Column="0"
                             BackgroundColor="Transparent"
                             HeightRequest="40"
                             WidthRequest="40"
                             Padding="5"
                             Clicked="OnBackButtonClicked"
                             VerticalOptions="Center"
                             HorizontalOptions="Start" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="İlmihal"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    <Label Text="Temel İslami Bilgiler"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Book / Carousel View -->
            <CarouselView x:Name="IlmihalCarousel"
                          Grid.Row="1"
                          PeekAreaInsets="0"
                          Loop="False"
                          IndicatorView="indicatorView">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="20,10,20,10"
                               CornerRadius="25"
                               HasShadow="True"
                               Padding="0"
                               BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#212121}"
                               IsClippedToBounds="True">
                            
                            <Grid RowDefinitions="Auto,*">
                                <!-- Card Header -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,20,20,10" BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#004D40}">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Emoji}" 
                                           FontSize="40" 
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1" 
                                           Text="{Binding Baslik}" 
                                           Margin="15,0,0,0"
                                           FontSize="22" 
                                           FontAttributes="Bold" 
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00695C, Dark=#FFFFFF}"/>
                                </Grid>
                                
                                <!-- Content List -->
                                <ScrollView Grid.Row="1" Padding="20">
                                    <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Icerikler}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Label Text="{Binding .}" 
                                                       FontSize="16" 
                                                       TextColor="{AppThemeBinding Light=#424242, Dark=#EEEEEE}"
                                                       LineBreakMode="WordWrap"/>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </ScrollView>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <!-- Indicators -->
            <IndicatorView x:Name="indicatorView"
                           Grid.Row="2"
                           IndicatorColor="{AppThemeBinding Light=#B2DFDB, Dark=#424242}"
                           SelectedIndicatorColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                           HorizontalOptions="Center" />
            
        </Grid>
    </Grid>
</ContentPage>
