<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.TemaAyarlari"
             Title="Tema Ayarları"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
    
    <Grid>
        <ScrollView Padding="20,10">
            <VerticalStackLayout Spacing="20">
                
                <!-- 1. HEADER CARD -->
                <Border StrokeShape="RoundRectangle 20"
                       Padding="20"
                       Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="Tema Ayarları"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        <Label Text="Görünümünüzü Kişiselleştirin"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- 2. HAZIR TEMALAR SECTION -->
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Hazır Temalar"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="❯"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Theme Cards Grid (3 Rows) -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15" RowSpacing="15">
                        
                        <!-- Ana Tema (Açık) (Row 0, Col 0) -->
                        <Border x:Name="AnaAcikFrame"
                               Grid.Row="0" Grid.Column="0"
                               StrokeShape="RoundRectangle 15"
                               Padding="0"
                               Stroke="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnThemeCardTapped" CommandParameter="MainLight"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="100, Auto">
                                <Image x:Name="AnaAcikImage"
                                       Grid.Row="0"
                                       Aspect="AspectFill"
                                       Source="sun_06.png"/>
                                
                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
                                    <Label Text="Ana (Açık)"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                    <Label x:Name="AnaAcikStatus"
                                           Text="(Seçili)"
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Ana Tema (Koyu) (Row 0, Col 1) -->
                        <Border x:Name="AnaKoyuFrame"
                               Grid.Row="0" Grid.Column="1"
                               StrokeShape="RoundRectangle 15"
                               Padding="0"
                               Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnThemeCardTapped" CommandParameter="MainDark"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="100, Auto">
                                <Image x:Name="AnaKoyuImage"
                                       Grid.Row="0"
                                       Aspect="AspectFill"
                                       Source="sun_09.png"/>
                                
                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
                                    <Label Text="Ana (Koyu)"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                    <Label x:Name="AnaKoyuStatus"
                                           Text=""
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Açık (Sabit) (Row 1, Col 0) -->
                        <Border x:Name="AcikFrame"
                               Grid.Row="1" Grid.Column="0"
                               StrokeShape="RoundRectangle 15"
                               Padding="0"
                               Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnThemeCardTapped" CommandParameter="Light"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="100, Auto">
                                <Image Grid.Row="0"
                                       Aspect="AspectFill"
                                       Source="bg_light.jpg"/>
                                
                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
                                    <Label Text="Açık"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                    <Label x:Name="AcikStatus"
                                           Text=""
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Simsiyah (Sabit) (Row 1, Col 1) -->
                        <Border x:Name="SimsiyahFrame"
                               Grid.Row="1" Grid.Column="1"
                               StrokeShape="RoundRectangle 15"
                               Padding="0"
                               Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnThemeCardTapped" CommandParameter="PitchBlack"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="100, Auto">
                                <Image Grid.Row="0"
                                       Aspect="AspectFill"
                                       Source="bg_dark.jpg"/>
                                
                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
                                    <Label Text="Simsiyah"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                    <Label x:Name="SimsiyahStatus"
                                           Text=""
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Özel Tema (Row 2, Col 0, ColSpan 2) -->
                        <Border x:Name="OzelFrame"
                               Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               StrokeShape="RoundRectangle 15"
                               Padding="0"
                               Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                               Opacity="0.5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnThemeCardTapped" CommandParameter="Custom"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="100, Auto">
                                <Image x:Name="OzelTemaImage"
                                       Grid.Row="0"
                                       Aspect="AspectFill"
                                       Source="sun_05.png"
                                       BackgroundColor="Gray"/> 
                                
                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
                                    <Label Text="Özel"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                                    <Label x:Name="OzelStatus"
                                           Text=""
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- 3. OZEL TEMA SECTION (Large Bottom Card) -->
                <Border x:Name="OzelTemaFrame"
                       StrokeShape="RoundRectangle 20"
                       Padding="20"
                       Margin="0,20,0,0"
                       Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                       HeightRequest="120">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OzelTemaOlustur_Clicked"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" 
                               Text="🎨" 
                               FontSize="40" 
                               VerticalOptions="Center"
                               Margin="0,0,15,0"/>
                        
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="Özel Tema Oluştur"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                            <Label Text="Kendi tarzını yarat"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                        
                        <!-- Optional: Indicate if a custom theme is active -->
                        <Label x:Name="OzelTemaStatus"
                               Grid.Column="1"
                               Text="(Seçili)"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                               HorizontalOptions="End"
                               VerticalOptions="Start"
                               IsVisible="False"/>
                    </Grid>
                </Border>


                <Label Text="⚠️ Tema özelliği beta aşamasındadır. Bazı hatalarla karşılaşabilirsiniz."
                       FontSize="12"
                       FontAttributes="Italic"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,10,0,0"
                       TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
