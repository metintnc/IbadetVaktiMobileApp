<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.zikirmatik"
             Title="Zikirmatik">

    <Grid>
        <!-- Arkaplan -->
        <Image x:Name="BackgroundImage"
                Aspect="AspectFill"
                HorizontalOptions="FillAndExpand"
                VerticalOptions="FillAndExpand" 
                IsVisible="False"/>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>

        <Grid RowDefinitions="Auto,*,Auto" Padding="20">
            
            <!-- Header -->
            <Frame Grid.Row="0"
                   x:Name="HeaderFrame"
                   CornerRadius="20"
                   Padding="20,25,20,20"
                   Margin="0,0,0,20"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label x:Name="ZikirBaslik" 
                               Text="Zikirmatik"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        <Label x:Name="SeciliZikirLabel" 
                               Text="Seçili Zikir: Sübhanallah"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                    </VerticalStackLayout>
                    
                    <!-- İlerleme Göstergesi -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="16"/>
                            <Label x:Name="IlerlemeYuzdeLabel" 
                                   Text="İlerleme: 0%"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="KalanLabel"
                                   Text="(Kalan: 100)"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </HorizontalStackLayout>
                        
                        <!-- Progress Bar -->
                        <Border Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="20"
                                BackgroundColor="{AppThemeBinding Light=#11000000, Dark=#22FFFFFF}">
                            <Grid>
                                <!-- İlerleme Dolgusu -->
                                <BoxView x:Name="IlerlemeIbresi"
                                         WidthRequest="0"
                                         HorizontalOptions="Start"
                                         CornerRadius="8"
                                         Margin="2">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{AppThemeBinding Light=#009688, Dark=#FFFFFF}" Offset="0.0"/>
                                            <GradientStop Color="{AppThemeBinding Light=#00796B, Dark=#EEEEEE}" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Ana Merkezi Alan -->
            <Grid Grid.Row="1" 
                  VerticalOptions="Center"
                  HorizontalOptions="Center"
                  WidthRequest="350"
                  HeightRequest="350">
                
                <!-- Dış Gradient Halka -->
                <Border StrokeThickness="6"
                        Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                        StrokeShape="RoundRectangle 175"
                        WidthRequest="350"
                        HeightRequest="350"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        Opacity="0.3"/>

                <!-- Orta Gradient Halka -->
                <Border StrokeThickness="4"
                        Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                        StrokeShape="RoundRectangle 150"
                        WidthRequest="300"
                        HeightRequest="300"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        Opacity="0.5"/>

                <!-- Ana Merkezi Daire (Tıklanabilir) -->
                <Frame x:Name="zikirbutton"
                       CornerRadius="125"
                       WidthRequest="250"
                       HeightRequest="250"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Padding="0"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#44FFFFFF, Dark=#44000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="zikirbutton_Clicked"/>
                    </Frame.GestureRecognizers>
                    
                    <Grid>
                        <!-- İlerleme Göstergesi (Circular Progress) -->
                        <ProgressBar x:Name="IlerlemeBar"
                                    Progress="0"
                                    ProgressColor="{AppThemeBinding Light=#009688, Dark=#FFFFFF}"
                                    IsVisible="False"/>
                        
                        <VerticalStackLayout Spacing="10"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                            <!-- Ana Sayaç -->
                            <Label x:Name="zikirsayisi" 
                                   Text="0"
                                   FontSize="72"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            
                            <!-- Hedef Göstergesi -->
                            <Label x:Name="HedefLabel"
                                   Text="Hedef: 100"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </Grid>

            <!-- Alt Butonlar -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="*,*,*,*,*"
                  ColumnSpacing="10"
                  Margin="0,20,0,0">
                
                <!-- Sıfırla Butonu -->
                <Frame Grid.Column="0"
                       CornerRadius="20"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="sifirla_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🔄"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label x:Name="SifirlaLabel"
                               Text="Sıfırla"
                               FontSize="11"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Hedef Ayarla Butonu -->
                <Frame Grid.Column="1"
                       CornerRadius="20"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="HedefAyarla_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="⚙️"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label x:Name="HedefAyarlaLabel"
                               Text="Hedef Ayarla"
                               FontSize="11"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Zikir Seç Butonu -->
                <Frame Grid.Column="2"
                       CornerRadius="20"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ZikirSec_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="📋"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label x:Name="ZikirSecLabel"
                               Text="Zikir Seç"
                               FontSize="11"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Ses/Titreşim Butonu -->
                <Frame Grid.Column="3"
                       CornerRadius="20"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SesTitresim_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label x:Name="SesTitresimIcon"
                               Text="🔊"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label x:Name="SesTitresimLabel"
                               Text="Ses/Titreşim"
                               FontSize="11"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- İstatistik Butonu -->
                <Frame Grid.Column="4"
                       CornerRadius="20"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Istatistik_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="📈"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label x:Name="IstatistikLabel"
                               Text="İstatistik"
                               FontSize="11"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>