<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.zikirmatik"
             Title="Zikirmatik">

    <Grid>
        <!-- Arkaplan -->
        <Image x:Name="BackgroundImage"
                Aspect="AspectFill"
                HorizontalOptions="FillAndExpand"
                VerticalOptions="FillAndExpand" 
                IsVisible="False"/>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>

        <Grid RowDefinitions="Auto,*,Auto" Padding="20">
            
            <!-- Header -->
            <Frame Grid.Row="0"
                   x:Name="HeaderFrame"
                   CornerRadius="20"
                   Padding="20,25,20,20"
                   Margin="0,0,0,20"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                <VerticalStackLayout Spacing="15">
                    <Grid VerticalOptions="Center">
                        <!-- Başlık ve Zikir İsmi (Ortalanmış) -->
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label x:Name="ZikirBaslik" 
                                   Text="Zikirmatik"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="SeciliZikirLabel" 
                                   Text="Seçili Zikir: Sübhanallah"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                        
                        <!-- Ses Butonu (Sağ Üst) -->
                        <Frame Padding="10"
                               CornerRadius="15"
                               HasShadow="False"
                               BackgroundColor="Transparent"
                               BorderColor="Transparent"
                               HorizontalOptions="End"
                               VerticalOptions="Start">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="SesTitresim_Clicked"/>
                            </Frame.GestureRecognizers>
                            <Label x:Name="SesTitresimIcon"
                                   Text="📳"
                                   FontSize="24"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                        </Frame>
                    </Grid>
                    
                    <!-- İlerleme Göstergesi -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="16"/>
                            <Label x:Name="IlerlemeYuzdeLabel" 
                                   Text="İlerleme: 0%"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="KalanLabel"
                                   Text="(Kalan: 100)"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </HorizontalStackLayout>
                        
                        <!-- Progress Bar -->
                        <Border Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="20"
                                BackgroundColor="{AppThemeBinding Light=#11000000, Dark=#22FFFFFF}">
                            <Grid>
                                <!-- İlerleme Dolgusu -->
                                <BoxView x:Name="IlerlemeIbresi"
                                         WidthRequest="0"
                                         HorizontalOptions="Start"
                                         CornerRadius="8"
                                         Margin="2">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{AppThemeBinding Light=#009688, Dark=#FFFFFF}" Offset="0.0"/>
                                            <GradientStop Color="{AppThemeBinding Light=#00796B, Dark=#EEEEEE}" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Ana Merkezi Alan -->
            <Grid Grid.Row="1" 
                  VerticalOptions="Center"
                  HorizontalOptions="Center"
                  WidthRequest="350"
                  HeightRequest="350">
                
                <!-- Dış Gradient Halka -->
                <Border StrokeThickness="6"
                        Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                        StrokeShape="RoundRectangle 175"
                        WidthRequest="350"
                        HeightRequest="350"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        Opacity="0.3"/>

                <!-- Orta Gradient Halka -->
                <Border StrokeThickness="4"
                        Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                        StrokeShape="RoundRectangle 150"
                        WidthRequest="300"
                        HeightRequest="300"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        Opacity="0.5"/>

                <!-- Ana Merkezi Daire (Tıklanabilir) -->
                <Frame x:Name="zikirbutton"
                       CornerRadius="125"
                       WidthRequest="250"
                       HeightRequest="250"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Padding="0"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#44FFFFFF, Dark=#44000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="zikirbutton_Clicked"/>
                    </Frame.GestureRecognizers>
                    
                    <Grid>
                        <!-- İlerleme Göstergesi (Circular Progress) -->
                        <ProgressBar x:Name="IlerlemeBar"
                                    Progress="0"
                                    ProgressColor="{AppThemeBinding Light=#009688, Dark=#FFFFFF}"
                                    IsVisible="False"/>
                        
                        <VerticalStackLayout Spacing="10"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                            <!-- Ana Sayaç -->
                            <Label x:Name="zikirsayisi" 
                                   Text="0"
                                   FontSize="72"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            
                            <!-- Hedef Göstergesi -->
                            <Label x:Name="HedefLabel"
                                   Text="Hedef: 100"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </Grid>

            <!-- Alt Butonlar -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="*,*,*,*"
                  ColumnSpacing="10"
                  Margin="0,20,0,0">
                
                <!-- Sıfırla Butonu -->
                <Frame Grid.Column="0"
                       CornerRadius="20"
                       Padding="10"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="sifirla_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🔄"
                               FontSize="24"
                               HorizontalOptions="Center"/>
                        <Label x:Name="SifirlaLabel"
                               Text="Sıfırla"
                               FontSize="10"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Hedef Ayarla Butonu -->
                <Frame Grid.Column="1"
                       CornerRadius="20"
                       Padding="10"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="HedefAyarla_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="⚙️"
                               FontSize="24"
                               HorizontalOptions="Center"/>
                        <Label x:Name="HedefAyarlaLabel"
                               Text="Hedef"
                               FontSize="10"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Zikir Seç Butonu -->
                <Frame Grid.Column="2"
                       CornerRadius="20"
                       Padding="10"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ZikirSec_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="📋"
                               FontSize="24"
                               HorizontalOptions="Center"/>
                        <Label x:Name="ZikirSecLabel"
                               Text="Seç"
                               FontSize="10"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- İstatistik Butonu -->
                <Frame Grid.Column="3"
                       CornerRadius="20"
                       Padding="10"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Istatistik_Clicked"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="📈"
                               FontSize="24"
                               HorizontalOptions="Center"/>
                        <Label x:Name="IstatistikLabel"
                               Text="İstatistik"
                               FontSize="10"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>

        <!-- Hedef Ayarlama Penceresi (Custom Pop-up) -->
        <Grid x:Name="TargetSelectionOverlay"
              BackgroundColor="#CC000000"
              IsVisible="False"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand"
              ZIndex="999">
              <Grid.GestureRecognizers>
                  <TapGestureRecognizer Tapped="OnCancelTarget_Clicked"/>
              </Grid.GestureRecognizers>
            
            <Frame BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
                   CornerRadius="25"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="320"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="20">
                    <Label Text="Hedef Ayarla" 
                           FontSize="22" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                    
                    <!-- Hazır Seçenekler -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Button Text="33" Clicked="OnPresetTarget_Clicked" 
                                BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33000000}" 
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                CornerRadius="10" Padding="0"/>
                        <Button Grid.Column="1" Text="99" Clicked="OnPresetTarget_Clicked" 
                                BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33000000}" 
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                CornerRadius="10" Padding="0"/>
                        <Button Grid.Column="2" Text="100" Clicked="OnPresetTarget_Clicked" 
                                BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33000000}" 
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                CornerRadius="10" Padding="0"/>
                        <Button Grid.Column="3" Text="500" Clicked="OnPresetTarget_Clicked" 
                                BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33000000}" 
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                CornerRadius="10" Padding="0"/>
                    </Grid>

                    <!-- Manuel Giriş -->
                    <Border Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,0">
                        <Entry x:Name="HedefEntry"
                               Placeholder="Özel bir sayı girin..."
                               Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               MaxLength="5"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                    </Border>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <!-- İptal Butonu -->
                        <Button Grid.Column="0"
                                Text="Vazgeç"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnCancelTarget_Clicked"/>
                        
                        <!-- Kaydet Butonu -->
                        <Button Grid.Column="1"
                                Text="Kaydet"
                                BackgroundColor="#00796B"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnSaveTarget_Clicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Zikir Seçim Listesi (Custom Pop-up) -->
        <Grid x:Name="ZikirSelectionOverlay"
              BackgroundColor="#CC000000"
              IsVisible="False"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand"
              ZIndex="999">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCancelZikirSelection_Clicked"/>
            </Grid.GestureRecognizers>

            <Frame BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
                   CornerRadius="25"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="320"
                   HeightRequest="500"
                   Padding="20"
                   HasShadow="True">
                <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="15">
                    <Label Grid.Row="0"
                           Text="Zikir Seç" 
                           FontSize="22" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="10" x:Name="ZikirListStack">
                            <!-- Zikir butonları kod tarafından doldurulacak veya burada statik tanımlanabilir -->
                            <Button Text="Sübhanallah" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="Elhamdülillah" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="Allahu Ekber" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="La ilahe illallah" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="Estağfirullah" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="Sübhanallahi ve bihamdihi" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="La havle vela kuvvete illa billah" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                            <Button Text="Allahümme salli ala seyyidina Muhammed" Clicked="OnSelectZikir_Clicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#00796B, Dark=#BDBDBD}" BorderColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" BorderWidth="1" CornerRadius="10"/>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Button Grid.Row="2"
                            Text="➕ Kendi Zikrini Gir"
                            BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33000000}" 
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                            CornerRadius="10"
                            Clicked="OnOpenCustomZikir_Clicked"/>

                    <Button Grid.Row="3"
                            Text="Vazgeç"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                            CornerRadius="12"
                            HeightRequest="45"
                            Clicked="OnCancelZikirSelection_Clicked"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Özel Zikir Giriş Penceresi -->
        <Grid x:Name="CustomZikirOverlay"
              BackgroundColor="#CC000000"
              IsVisible="False"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand"
              ZIndex="1000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCancelCustomZikir_Clicked"/>
            </Grid.GestureRecognizers>

            <Frame BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
                   CornerRadius="25"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="320"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="20">
                    <Label Text="Özel Zikir" 
                           FontSize="22" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

                    <Border Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,0">
                        <Entry x:Name="CustomZikirEntry"
                               Placeholder="Zikrinizi buraya yazın..."
                               HorizontalTextAlignment="Center"
                               MaxLength="50"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Button Grid.Column="0"
                                Text="Vazgeç"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnCancelCustomZikir_Clicked"/>

                        <Button Grid.Column="1"
                                Text="Kaydet"
                                BackgroundColor="#00796B"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnSaveCustomZikir_Clicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Sıfırla Onay Penceresi (Custom Pop-up) -->
        <Grid x:Name="ResetConfirmationOverlay"
              BackgroundColor="#CC000000"
              IsVisible="False"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand"
              ZIndex="999">
              <Grid.GestureRecognizers>
                  <TapGestureRecognizer Tapped="OnCancelReset_Clicked"/>
              </Grid.GestureRecognizers>
            
            <Frame BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
                   CornerRadius="25"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="300"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="20">
                    <Label Text="⚠️" 
                           FontSize="40" 
                           HorizontalOptions="Center"/>
                    
                    <Label Text="Sıfırlansın mı?" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                    
                    <Label Text="Zikir sayacını sıfırlamak istediğinize emin misiniz?" 
                           FontSize="14" 
                           HorizontalOptions="Center" 
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <!-- İptal Butonu -->
                        <Button Grid.Column="0"
                                Text="Vazgeç"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnCancelReset_Clicked"/>
                        
                        <!-- Onay Butonu -->
                        <Button Grid.Column="1"
                                Text="Sıfırla"
                                BackgroundColor="#D32F2F"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="45"
                                Clicked="OnConfirmReset_Clicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>