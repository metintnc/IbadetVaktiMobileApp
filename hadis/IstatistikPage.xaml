<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.IstatistikPage"
             Title="İstatistikler"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label x:Name="ToplamZikirLabel"
                   Style="{StaticResource SubHeadline}"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                   HorizontalOptions="Center"/>
            <Label x:Name="EnCokZikirLabel"
                   Style="{StaticResource AnaLabel}"
                   HorizontalOptions="Center"/>
            <Label Text="Son 7 Gün Detaylı Liste" Style="{StaticResource Headline}" FontSize="18"/>
            <CollectionView x:Name="HaftaListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4" Padding="10" Style="{StaticResource ayetframe}">
                            <VerticalStackLayout>
                                <Label Text="{Binding Tarih}" FontAttributes="Bold" FontSize="15" Style="{StaticResource AnaLabel}"/>
                                <CollectionView ItemsSource="{Binding Zikirler}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <HorizontalStackLayout>
                                                <Label Text="{Binding Ad}" FontSize="14"/>
                                                <Label Text=": " FontSize="14"/>
                                                <Label Text="{Binding Adet}" FontSize="14" FontAttributes="Bold"/>
                                            </HorizontalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
