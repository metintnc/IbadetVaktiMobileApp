<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.IstatistikPage"
             Title="İstatistikler"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">
            
            <!-- Özet İstatistikler Grid'i -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto, Auto" ColumnSpacing="15" RowSpacing="15">
                
                <!-- 1. Satır: Toplam ve Bugün -->
                <!-- Toplam Kartı -->
                <Frame Grid.Row="0" Grid.Column="0"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Toplam Zikir" 
                               FontSize="12" 
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="ToplamZikirLabel"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Bugün Kartı -->
                <Frame Grid.Row="0" Grid.Column="1"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Bugün" 
                               FontSize="12" 
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="BugunZikirLabel"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#FFA000, Dark=#FFCA28}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- 2. Satır: Zincir ve Ortalama -->
                <!-- Zincir (Streak) Kartı -->
                <Frame Grid.Row="1" Grid.Column="0"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="🔥 " FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Zincir" 
                                   FontSize="12" 
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </Grid>
                        <Label x:Name="ZincirLabel"
                               Text="0 Gün"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Ortalama Kartı -->
                <Frame Grid.Row="1" Grid.Column="1"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="📊 " FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Ortalama" 
                                   FontSize="12" 
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </Grid>
                        <Label x:Name="OrtalamaLabel"
                               Text="0"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#42A5F5}"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- En Çok Çekilen Kartı (Tek Satır) -->
            <Frame CornerRadius="15"
                   Padding="15"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                    <Label Grid.Column="0" 
                           Text="🏆" 
                           FontSize="32" 
                           VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="En Çok Çekilen" 
                               FontSize="12" 
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="EnCokZikirLabel"
                               Text="-"
                               FontSize="16"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Haftalık Grafik -->
            <Frame CornerRadius="20"
                   Padding="20"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Son 7 Gün" 
                           FontSize="16" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}"/>
                    
                    <!-- Grafik Alanı (Grid Code-Behind'da doldurulacak) -->
                    <Grid x:Name="ChartGrid" 
                          HeightRequest="150" 
                          ColumnDefinitions="*,*,*,*,*,*,*" 
                          ColumnSpacing="8"
                          VerticalOptions="End"/>
                </VerticalStackLayout>
            </Frame>



        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
