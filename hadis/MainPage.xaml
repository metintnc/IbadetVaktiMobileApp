<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:hadis.ViewModels"
             x:Class="hadis.MainPage" 
             x:DataType="vm:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Arkaplan Resmi - En altta -->
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="kuran_light.png" Dark="kuranarkaplan.png" />
            </Image.Source>
        </Image>
        <!-- Arkaplan Overlay - Ortada -->
        <Grid x:Name="BackgroundOverlay"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand"
              IsVisible="False" />

        <!-- İnternet Hatası Uyarısı (En Üstte) -->
        <Grid x:Name="InternetErrorOverlay"
              BackgroundColor="{AppThemeBinding Light=#DDFFFFFF, Dark=#DD000000}"
              IsVisible="{Binding IsInternetErrorVisible}"
              ZIndex="999"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand">
            <VerticalStackLayout Spacing="20" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="{Binding ErrorTitle}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"/>
                <Label Text="{Binding ErrorDescription}"
                       FontSize="16"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}"
                       Padding="40,0"/>
                <ActivityIndicator IsRunning="True" 
                                   Color="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                   HorizontalOptions="Center"/>
                <Label Text="Bağlantı bekleniyor..."
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Konum Hatası Uyarısı (İnternet Uyarısı ile aynı seviyede) -->
        <Grid x:Name="LocationErrorOverlay"
              BackgroundColor="{AppThemeBinding Light=#DDFFFFFF, Dark=#DD000000}"
              IsVisible="{Binding IsLocationErrorVisible}"
              ZIndex="999"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand">
            <VerticalStackLayout Spacing="20" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="📍"
                       FontSize="60"
                       HorizontalOptions="Center"/>
                <Label Text="Konum Seçimi Gerekli"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                <Label Text="Namaz vakitlerini hesaplayabilmek için bir şehir seçmelisiniz veya konum izni vermelisiniz."
                       FontSize="16"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}"
                       Padding="40,0"/>
                
                <Button Text="Şehir Seç / Konum İzni"
                        BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        Padding="30,15"
                        Clicked="OnLocationErrorRetry_Clicked"/>
            </VerticalStackLayout>
        </Grid>

        <!-- İçerik - En üstte -->
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" 
              ColumnDefinitions="*" 
              Padding="20" 
              Margin="0,0,0,0"
              BackgroundColor="Transparent">

            <!-- Ana Geri Sayım Frame -->
            <StackLayout Grid.Row="0" Spacing="10">
                <Border x:Name="MainCountdownFrame" 
                       Style="{StaticResource BorderFrameStyle}" 
                       Padding="20" 
                       StrokeShape="RoundRectangle 15" 
                       Opacity="0.95"
                       Stroke="#FFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="namazismi" Text="{Binding NamazIsmi}" HorizontalOptions="Center" FontSize="25">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.5" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="kalan" Text="{Binding KalanSure}" HorizontalOptions="Center" FontSize="45">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.5" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" Text="Kaldı" TextColor="White" HorizontalOptions="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.5" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="Konum" Text="{Binding KonumText}" HorizontalOptions="Center" FontSize="10">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Konum_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" Text="{Binding HicriTarih}" HorizontalOptions="Center" FontSize="13" Margin="0,5,0,0">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>
            </StackLayout>

            <!-- İlk Satır Namaz Vakitleri -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" RowSpacing="30" ColumnSpacing="10" Margin="0,20,0,0" >

                <Border Grid.Column="0"
                        x:Name="ImsakFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="imsakyazı" Text="İmsak" HorizontalOptions="Center" FontSize="16" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="imsakvakit" Text="{Binding ImsakVakit}" TextColor="{Binding ImsakVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>

                <Border Grid.Column="1"
                        x:Name="GunesFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="gunesyazı" Text="Güneş" HorizontalOptions="Center" FontSize="16" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="gunesvakit" Text="{Binding GunesVakit}" TextColor="{Binding GunesVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>

                <Border Grid.Column="2"
                        x:Name="OgleFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="ogleyazı" Text="Öğle" HorizontalOptions="Center" FontSize="16" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="oglevakit" Text="{Binding OgleVakit}" TextColor="{Binding OgleVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>
            </Grid>

            <!-- İkinci Satır Namaz Vakitleri -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" RowSpacing="30" ColumnSpacing="10" Margin="0,10,0,0" >
                <Border Grid.Column="0"
                        x:Name="IkindiFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="ikindiyazı" Text="İkindi" HorizontalOptions="Center" FontSize="16" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="ikindivakit" Text="{Binding IkindiVakit}" TextColor="{Binding IkindiVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>

                <Border Grid.Column="1"
                        x:Name="AksamFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="aksamyazı" Text="Akşam" HorizontalOptions="Center" FontSize="17" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="aksamvakit" Text="{Binding AksamVakit}" TextColor="{Binding AksamVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>

                <Border Grid.Column="2"
                        x:Name="YatsiFrame" 
                        Style="{StaticResource BorderFrameStyle}" 
                        StrokeShape="RoundRectangle 20" 
                        Padding="10"
                        Stroke="#CCFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60FFFFFF" Offset="0.0" />
                            <GradientStop Color="#50FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Style="{StaticResource AnaLabel}" x:Name="yatsıyazı" Text="Yatsı" HorizontalOptions="Center" FontSize="17" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                        <Label Style="{StaticResource AnaLabel}" x:Name="yatsıvakit" Text="{Binding YatsiVakit}" TextColor="{Binding YatsiVakitColor}" HorizontalOptions="Center" HorizontalTextAlignment="Center">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="1,1" Radius="1" Opacity="0.4" />
                            </Label.Shadow>
                        </Label>
                    </StackLayout>
                </Border>
            </Grid>
            
            <!-- Boşluk - Grid.Row="3" * ile esnek alan -->
            
            <!-- Ayet Frame - En Altta -->
            <Border Grid.Row="4" 
                   x:Name="AyetFrame" 
                   VerticalOptions="End" 
                   Style="{StaticResource AyetBorderStyle}"
                   Padding="15"
                   Margin="0,0,0,10"
                   StrokeShape="RoundRectangle 20"
                   Stroke="#80FFFFFF">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#30FFFFFF" Offset="0.0" />
                        <GradientStop Color="#20FFFFFF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="gununayeti" Text="{Binding GununAyeti}" Style="{StaticResource AnaLabel}" LineBreakMode="WordWrap">
                        <Label.Shadow>
                            <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.4" />
                        </Label.Shadow>
                    </Label>
                </StackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
