<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Ayarlar"
             Title="Ayarlar">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView VerticalScrollBarVisibility="Never"
                    HorizontalScrollBarVisibility="Never"
                    Padding="20">
            <VerticalStackLayout Spacing="20">
                
                <!-- Header -->
                <Frame x:Name="HeaderFrame"
                       CornerRadius="20"
                       Padding="20,25"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Label x:Name="AyarlarTitle" 
                           Text="Ayarlar"
                           FontSize="32"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                </Frame>

                <!-- Grid for main settings cards -->
                <Grid RowDefinitions="Auto,Auto" 
                      ColumnDefinitions="*,*"
                      RowSpacing="15"
                      ColumnSpacing="15">
                    
                    <!-- Tema Ayarlari Card -->
                    <Frame Grid.Row="0" Grid.Column="0"
                           x:Name="TemaFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TemaButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🎨"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="TemaTitle"
                                   Text="Tema Ayarlari"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="TemaSubtitle"
                                   Text="Görünüm ve Renkler"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Bildirim Ayarlari Card -->
                    <Frame Grid.Row="0" Grid.Column="1"
                           x:Name="BildirimFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="BildirimButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🔔"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="BildirimTitle"
                                   Text="Bildirim Ayarlari"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="BildirimSubtitle"
                                   Text="Ezan ve Hatirlaticilar"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Widget Ayarlari Card -->
                    <Frame Grid.Row="1" Grid.Column="0"
                           x:Name="WidgetFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="WidgetButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📱"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="WidgetTitle"
                                   Text="Widget Ayarlari"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="WidgetSubtitle"
                                   Text="Ana Ekran Araçlari"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Konum Ayarlari Card -->
                    <Frame Grid.Row="1" Grid.Column="1"
                           x:Name="KonumFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="KonumButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📍"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="KonumTitle"
                                   Text="Konum Ayarlari"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="SeciliKonumLabel" 
                                   Text="Şehir ve GPS" 
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                </Grid>

                <!-- Genel Ayarlar -->
                <Frame x:Name="VeriYonetimiFrame"
                       CornerRadius="20"
                       Padding="20"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <VerticalStackLayout Spacing="15">
                        <Label x:Name="VeriYonetimiTitle"
                               Text="Genel Ayarlar"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Button x:Name="ClearCacheButton"
                                Text="Önbelleği Temizle" 
                                Clicked="ClearCacheButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#F57C00, Dark=#FF9800}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"
                                HorizontalOptions="Fill"/>
                        
                        <Button x:Name="ResetButton"
                                Text="Ayarlari Sifirla" 
                                Clicked="ResetSettingsButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#D32F2F, Dark=#F44336}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Hakkinda -->
                <Frame x:Name="HakkindaFrame"
                       CornerRadius="20"
                       Padding="20"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="HakkindaTitle"
                               Text="Hakkinda"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Label x:Name="VersionLabel" 
                               Text="Versiyon: 1.0.0" 
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="CopyrightLabel"
                               Text="2024 Namaz Vakti Uygulamasi" 
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
