<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Ayarlar"
             Title="Ayarlar">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.80" Dark="0.50" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView VerticalScrollBarVisibility="Never"
                    HorizontalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <Label x:Name="AyarlarTitle" 
                       Text="Ayarlar"
                       FontSize="28"
                       FontAttributes="Bold"
                       Margin="0,10,0,20"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>

                <Frame x:Name="BildirimFrame" Style="{StaticResource BorderFrame}" Padding="5" BackgroundColor="Transparent">
                    <Button x:Name="BildirimButton"
                            Text="Bildirimler"
                            Clicked="BildirimButton_Clicked"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            Padding="15"/>
                </Frame>

                <Frame x:Name="TemaFrame" Style="{StaticResource BorderFrame}" Padding="5" BackgroundColor="Transparent">
                    <Button x:Name="TemaButton"
                            Text="Tema"
                            Clicked="TemaButton_Clicked"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            Padding="15"/>
                </Frame>

                <Frame x:Name="WidgetFrame" Style="{StaticResource BorderFrame}" Padding="5" BackgroundColor="Transparent">
                    <Button x:Name="WidgetButton"
                            Text="Widget"
                            Clicked="WidgetButton_Clicked"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            Padding="15"/>
                </Frame>

                <Frame x:Name="KonumFrame" Style="{StaticResource BorderFrame}" Padding="5" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="5">
                        <Button x:Name="KonumButton"
                                Text="Konum"
                                Clicked="KonumButton_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                FontSize="18"
                                FontAttributes="Bold"
                                HorizontalOptions="Fill"
                                Padding="15,15,15,5"/>
                        <Label x:Name="SeciliKonumLabel" 
                               Text="Mevcut: Otomatik (GPS)" 
                               FontSize="12"
                               Padding="15,0,15,10"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="VeriYonetimiFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="VeriYonetimiTitle"
                               Text="Veri Yonetimi"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Button x:Name="ClearCacheButton"
                                Text="Onbellegi Temizle" 
                                Clicked="ClearCacheButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#F57C00, Dark=#FF9800}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"/>
                        
                        <Button x:Name="ResetButton"
                                Text="Ayarlari Sifirla" 
                                Clicked="ResetSettingsButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#D32F2F, Dark=#F44336}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="HakkindaFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="HakkindaTitle"
                               Text="Hakkinda"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Label x:Name="VersionLabel" 
                               Text="Versiyon: 1.0.0" 
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="CopyrightLabel"
                               Text="2024 Namaz Vakti Uygulamasi" 
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
