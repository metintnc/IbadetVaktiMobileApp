<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Ayarlar"
             Title="Ayarlar">
    
    <Grid>
        <Image Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="bg_dark.jpg" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.80" Dark="0.50" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView VerticalScrollBarVisibility="Never"
                    HorizontalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <Label x:Name="AyarlarTitle" 
                       Text="Ayarlar"
                       FontSize="28"
                       FontAttributes="Bold"
                       Margin="0,10,0,20"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>

                <Frame x:Name="BildirimFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Bildirimler"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Namaz Vakti Bildirimleri" 
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"/>
                            <Switch x:Name="BildirimSwitch" 
                                    Grid.Column="1" 
                                    IsToggled="True"
                                    OnColor="#4CAF50"
                                    ThumbColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="KonumFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Konum Ayarlari"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Button Text="Konumu Degistir"
                                Clicked="SehirSecButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                TextColor="White"
                                CornerRadius="12"
                                Padding="12,10"
                                FontSize="15"
                                HorizontalOptions="Fill"/>
                        
                        <Label x:Name="SeciliKonumLabel" 
                               Text="Mevcut Konum: Otomatik" 
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                               Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="GorunumFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Gorunum"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                            <Label Text="Tema" 
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"/>
                            <Picker x:Name="ThemePicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="ThemePicker_SelectedIndexChanged"
                                    HorizontalOptions="End"
                                    WidthRequest="150"
                                    TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"
                                    FontSize="14">
                                <Picker.Items>
                                    <x:String>Sistem Temasi</x:String>
                                    <x:String>Acik Tema</x:String>
                                    <x:String>Koyu Tema</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="VeriYonetimiFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Veri Yonetimi"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Button Text="Onbellegi Temizle" 
                                Clicked="ClearCacheButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#F57C00, Dark=#FF9800}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"/>
                        
                        <Button Text="Ayarlari Sifirla" 
                                Clicked="ResetSettingsButton_Clicked"
                                BackgroundColor="{AppThemeBinding Light=#D32F2F, Dark=#F44336}"
                                TextColor="White"
                                CornerRadius="15"
                                Padding="15,12"
                                FontAttributes="Bold"
                                FontSize="15"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="HakkindaFrame" Style="{StaticResource BorderFrame}" Padding="15" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Hakkinda"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#81C784}"/>
                        
                        <Label x:Name="VersionLabel" 
                               Text="Versiyon: 1.0.0" 
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label Text="2024 Namaz Vakti Uygulamasi" 
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
