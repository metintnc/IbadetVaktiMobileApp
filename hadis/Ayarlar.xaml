<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.Ayarlar"
             Title="Ayarlar">
    
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="ayarlararkaplan.png" />
            </Image.Source>
        </Image>
        
        <BoxView HorizontalOptions="FillAndExpand"
                 VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.75" Dark="0.45" />
            </BoxView.Opacity>
        </BoxView>
        
        <ScrollView VerticalScrollBarVisibility="Never"
                    HorizontalScrollBarVisibility="Never"
                    Padding="20">
            <VerticalStackLayout Spacing="20">
                
                <!-- Header -->
                <Frame x:Name="HeaderFrame"
                       CornerRadius="20"
                       Padding="20,25"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <Label x:Name="AyarlarTitle" 
                           Text="Ayarlar"
                           FontSize="32"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                </Frame>

                <!-- Grid for main settings cards -->
                <Grid RowDefinitions="Auto,Auto,Auto" 
                      ColumnDefinitions="*,*"
                      RowSpacing="15"
                      ColumnSpacing="15">
                    
                    <!-- Tema Ayarlari Card -->
                    <Frame Grid.Row="0" Grid.Column="0"
                           x:Name="TemaFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TemaButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🎨"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="TemaTitle"
                                   Text="Tema Ayarları"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="TemaSubtitle"
                                   Text="Görünüm ve Renkler"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Bildirim Ayarlari Card -->
                    <Frame Grid.Row="0" Grid.Column="1"
                           x:Name="BildirimFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="BildirimButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🔔"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="BildirimTitle"
                                   Text="Bildirim Ayarları"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="BildirimSubtitle"
                                   Text="Ezan ve Hatırlatıcılar"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Widget Ayarlari Card -->
                    <Frame Grid.Row="1" Grid.Column="0"
                           x:Name="WidgetFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           Opacity="0.6"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="WidgetButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📱"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="WidgetTitle"
                                   Text="Widget Ayarları"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Frame CornerRadius="10" 
                                   Padding="6,3"
                                   HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}"
                                   BorderColor="{AppThemeBinding Light=#FFB74D, Dark=#FF8A65}"
                                   HorizontalOptions="Center">
                                <Label Text="🚧 Yakında"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#E65100, Dark=#FFAB91}"/>
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Konum Ayarlari Card -->
                    <Frame Grid.Row="1" Grid.Column="1"
                           x:Name="KonumFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="KonumButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📍"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="KonumTitle"
                                   Text="Konum Ayarları"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="SeciliKonumLabel" 
                                   Text="Şehir ve GPS" 
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Yakindaki Camiler Card -->
                    <Frame Grid.Row="2" Grid.Column="0"
                           x:Name="CamilerFrame"
                           CornerRadius="20"
                           Padding="20"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                           BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="YakinCamilerButton_Clicked"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🕌"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="CamilerTitle"
                                   Text="Yakındaki Camiler"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                            <Label x:Name="CamilerSubtitle"
                                   Text="Haritada Görüntüle"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                </Grid>

                <!-- Hakkinda -->
                <Frame x:Name="HakkindaFrame"
                       CornerRadius="20"
                       Padding="20"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#22FFFFFF, Dark=#33000000}">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="HakkindaTitle"
                               Text="Hakkında"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                        
                        <Label x:Name="VersionLabel" 
                               Text="Versiyon: 1.0.0" 
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>
                        <Label x:Name="CopyrightLabel"
                               Text="© 2025 Namaz Vakti Uygulaması" 
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                        
                        <Label x:Name="GizlilikPolitikasiLabel"
                               Text="Gizlilik Politikası"
                               FontSize="14"
                               FontAttributes="Italic"
                               TextDecorations="Underline"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="GizlilikPolitikasi_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
