<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.SehirSecim"
             Title="Konum Seç"
             NavigationPage.HasNavigationBar="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid>
        
        <Grid RowDefinitions="Auto,Auto,*" Padding="20,10">
            
            <!-- 1. Header Frame (Özel Üst Bar) -->
            <Frame Grid.Row="0"
                   CornerRadius="20"
                   Padding="15"
                   Margin="0,10,0,10"
                   HasShadow="True"
                   BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#EEFFFFFF, Dark=#AA111111}">
                <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                     <!-- Geri Butonu (Entegre) -->

                                 
                    <!-- Basit Geri Dönüş için Label Button -->
                     <Label Grid.Column="0"
                            x:Name="BackLabel"
                            Text="❮"
                            FontSize="24"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                            Margin="0,0,10,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackLabelClicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Grid.Column="1" 
                           x:Name="TitleLabel"
                           Text="Konum Seç"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                           Margin="-30,0,0,0"/> <!-- Geri butonu payını dengelemek için margin -->
                </Grid>
            </Frame>
            
            <!-- 2. Arama ve Otomatik Konum (Sabit Alan) -->
            <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                <!-- Arama Kutusu -->
                <Frame Padding="0"
                       CornerRadius="15"
                       HasShadow="False"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#33E0F2F1, Dark=#33000000}">
                    <SearchBar x:Name="SearchBar"
                               Placeholder="Şehir ara..."
                               TextChanged="SearchBar_TextChanged"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               CancelButtonColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                </Frame>

                <!-- Otomatik Konum Kartı -->
                <Frame CornerRadius="15"
                       Padding="15"
                       HasShadow="True"
                       BorderColor="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33004D40}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFindLocationTapped"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="📍" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" 
                               Text="Konumumu Bul (Otomatik)" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" VerticalOptions="Center"/>
                    </Grid>
                </Frame>
            </VerticalStackLayout>
            
            <!-- 3. Şehir Listesi -->
            <CollectionView Grid.Row="2" 
                            x:Name="CitiesCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="CitiesCollectionView_SelectionChanged"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15,12" 
                               Margin="2,4"
                               CornerRadius="12"
                               BorderColor="{AppThemeBinding Light=#20009688, Dark=#20FFFFFF}"
                               BackgroundColor="{AppThemeBinding Light=#CCFFFFFF, Dark=#CC1E1E1E}"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCityTapped"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#424242, Dark=#EEEEEE}"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="24"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#BDBDBD, Dark=#616161}"
                                       TranslationX="5"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
        </Grid>
    </Grid>
</ContentPage>
