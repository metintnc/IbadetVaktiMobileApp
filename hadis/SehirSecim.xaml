<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:hadis.ViewModels"
             x:Class="hadis.SehirSecim"
             x:Name="SehirSecimPage"
             x:DataType="viewmodels:SehirSecimViewModel"
             Title="Konum Seç"
             NavigationPage.HasNavigationBar="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid>
        
        <Grid RowDefinitions="Auto,Auto,*" Padding="20,10">
            
            <!-- 1. Header Frame (Özel Üst Bar) -->
            <Border Grid.Row="0"
                   StrokeShape="RoundRectangle 20"
                   Padding="15"
                   Margin="0,10,0,10"
                   Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                   BackgroundColor="{AppThemeBinding Light=#EEFFFFFF, Dark=#AA111111}">
                <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                     <!-- Geri Butonu (Entegre) -->
 
                                 
                    <!-- Basit Geri Dönüş için Label Button -->
                     <Label Grid.Column="0"
                            x:Name="BackLabel"
                            Text="❮"
                            FontSize="24"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                            Margin="0,0,10,0"
                            IsVisible="{Binding IsBackVisible}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Grid.Column="1" 
                           x:Name="TitleLabel"
                           Text="{Binding Title}"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                           Margin="-30,0,0,0"/> <!-- Geri butonu payını dengelemek için margin -->
                </Grid>
            </Border>
            
            <!-- 2. Arama ve Otomatik Konum (Sabit Alan) -->
            <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                <!-- Arama Kutusu -->
                <Border Padding="0"
                       StrokeShape="RoundRectangle 15"
                       Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#33E0F2F1, Dark=#33000000}">
                    <SearchBar x:Name="SearchBar"
                               Placeholder="{Binding SearchPlaceholder}"
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                               CancelButtonColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>
                </Border>

                <!-- Otomatik Konum Kartı -->
                <Border StrokeShape="RoundRectangle 15"
                       Padding="15"
                       Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                       BackgroundColor="{AppThemeBinding Light=#E0F2F1, Dark=#33004D40}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FindLocationCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="📍" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" 
                               Text="Konumumu Bul (Otomatik)" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}" VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            
            <!-- 3. Şehir Listesi -->
            <CollectionView Grid.Row="2" 
                            x:Name="CitiesCollectionView"
                            ItemsSource="{Binding FilteredCities}"
                            SelectedItem="{Binding SelectedCity, Mode=TwoWay}"
                            SelectionMode="Single"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,12" 
                               Margin="2,4"
                               StrokeShape="RoundRectangle 12"
                               Stroke="{AppThemeBinding Light=#20009688, Dark=#20FFFFFF}"
                               BackgroundColor="{AppThemeBinding Light=#CCFFFFFF, Dark=#CC1E1E1E}">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#424242, Dark=#EEEEEE}"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="24"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#BDBDBD, Dark=#616161}"
                                       TranslationX="5"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
        </Grid>

        <!-- Loading Overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="#AA000000"
              ZIndex="10">
            <Border StrokeShape="RoundRectangle 20"
                    Padding="35,30"
                    BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#F0222222}"
                    Stroke="{AppThemeBinding Light=#80009688, Dark=#80FFFFFF}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       Color="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                                       WidthRequest="48"
                                       HeightRequest="48"
                                       HorizontalOptions="Center"/>
                    <Label Text="Konum bulunuyor..."
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
