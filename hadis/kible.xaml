<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.kible">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand" 
               IsVisible="False"/>
        <BoxView HorizontalOptions="FillAndExpand"
          VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.65" Dark="0.3" />
            </BoxView.Opacity>
        </BoxView>
        <Grid RowDefinitions="Auto,*"  Style="{StaticResource Background}" >
        <VerticalStackLayout Grid.Row="0" Spacing="5" VerticalOptions="Center" Margin="0,20,0,0">
            <Label Text="0°" HorizontalOptions="Center" x:Name="AciDegeri" FontSize="35" Style="{StaticResource AnaLabel}"/>
            
            <Label x:Name="AccuracyStatusLabel"
                   Text="Kalibrasyon: Bekleniyor..."
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"/>

            <Label x:Name="AccuracyWarningLabel"
                   Text="Doğruluk için cihazı düz tutun ve 8 işareti çizin (∞)" 
                   FontSize="12" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                   Opacity="0.9"
                   IsVisible="False"/>
        </VerticalStackLayout>
        <Image Grid.Row="1" x:Name="kibleoku" Style="{StaticResource KibleOk}" Aspect="AspectFit" VerticalOptions="Fill" HorizontalOptions="Fill"/>


    </Grid>


    </Grid>


</ContentPage>