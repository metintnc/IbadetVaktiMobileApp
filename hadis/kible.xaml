<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.kible">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="bg_light.jpg" Dark="z.png" />
            </Image.Source>
        </Image>
        <BoxView HorizontalOptions="FillAndExpand"
          VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0.65" Dark="0.3" />
            </BoxView.Opacity>
        </BoxView>
        <Grid RowDefinitions="Auto,*"  Style="{StaticResource Background}" >
        <VerticalStackLayout Grid.Row="0" Spacing="5" VerticalOptions="Center" Margin="0,20,0,0">
            <Label Text="0°" HorizontalOptions="Center" x:Name="AciDegeri" FontSize="35" Style="{StaticResource AnaLabel}"/>
            
            <!-- Kalibrasyon Uyarısı (Sadece Düşük Doğrulukta Görünür) -->
            <Frame x:Name="CalibrationWarningFrame"
                   BackgroundColor="#CCFF5252"
                   Padding="15,10"
                   CornerRadius="15"
                   HorizontalOptions="Center"
                   Margin="20,10,20,0"
                   IsVisible="False"
                   HasShadow="False">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="⚠️" 
                           FontSize="24" 
                           VerticalOptions="Center"/>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pusula Hatalı!" 
                               FontAttributes="Bold"
                               TextColor="White"
                               FontSize="16"/>
                        <Label Text="Doğru sonuç için telefonunuzu 8 rakamı çizecek şekilde hareket ettirin." 
                               TextColor="White"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               MaximumWidthRequest="250"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>
        </VerticalStackLayout>
        <Image Grid.Row="1" x:Name="kibleoku" Style="{StaticResource KibleOk}" Aspect="AspectFit" VerticalOptions="Fill" HorizontalOptions="Fill"/>


    </Grid>


    </Grid>


</ContentPage>