<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hadis.kible">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand">
            <Image.Source>
                <AppThemeBinding Light="z_light.webp" Dark="z.webp" />
            </Image.Source>
        </Image>
        <BoxView HorizontalOptions="FillAndExpand"
          VerticalOptions="FillAndExpand">
            <BoxView.Color>
                <AppThemeBinding Light="White" Dark="Black" />
            </BoxView.Color>
            <BoxView.Opacity>
                <AppThemeBinding Light="0" Dark="0.3" />
            </BoxView.Opacity>
        </BoxView>
        <Grid RowDefinitions="Auto,*"  Style="{StaticResource Background}" >
        <!-- Header - Kuran Page Style -->
        <Label Grid.Row="0"
               Text="Kıble Pusulası"
               FontSize="36"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="0,50,0,10"
               TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"/>

        <!-- Main Content Group - Row 1 (Centered vertically in available space) -->
        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             Spacing="0">
            
            <!-- Açı ve Tik Wrapper -->
            <VerticalStackLayout Spacing="0"
                                 HorizontalOptions="Center"
                                 ZIndex="50">
                <Label Text="0°" 
                       x:Name="AciDegeri" 
                       HorizontalOptions="Center"
                       FontSize="35" 
                       Style="{StaticResource AnaLabel}"/>
                
                <Label x:Name="QiblaCheckmark"
                       Text="✅"
                       FontSize="24"
                       HorizontalOptions="Center"
                       Opacity="0"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"/>
            </VerticalStackLayout>

            <!-- Kıble Oku -->
            <Image x:Name="kibleoku" 
                   Style="{StaticResource KibleOk}" 
                   Aspect="AspectFit" 
                   VerticalOptions="Start"
                   HorizontalOptions="Fill"
                   Margin="20,0,20,0"/>
        </VerticalStackLayout>

        <!-- Kalibrasyon Uyarısı - Row 1 Overlay Bottom -->
        <Border Grid.Row="1"
               x:Name="CalibrationWarningFrame"
               BackgroundColor="#CCFF5252"
               Padding="15,10"
               StrokeShape="RoundRectangle 15"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="20,10,20,50"
               IsVisible="False"
               ZIndex="99">
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="⚠️" 
                       FontSize="24" 
                       VerticalOptions="Center"/>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Pusula Kalibrasyonu" 
                           FontAttributes="Bold"
                           TextColor="White"
                           FontSize="16"/>
                    <Label Text="Doğru sonuç için telefonunuzu 8 rakamı çizecek şekilde hareket ettirin." 
                           TextColor="White"
                           FontSize="12"
                           LineBreakMode="WordWrap"
                           MaximumWidthRequest="250"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Konum İzni Uyarısı - Overlay -->
        <Border Grid.Row="1"
               x:Name="LocationWarningFrame"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
               Padding="20"
               StrokeShape="RoundRectangle 20"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="30"
               IsVisible="False"
               ZIndex="100"
               Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}">
            <VerticalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="📍" 
                       FontSize="40" 
                       HorizontalOptions="Center"/>
                
                <Label Text="Konum İzni Gerekli" 
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#00796B, Dark=#FFFFFF}"
                       FontSize="20"
                       HorizontalOptions="Center"/>
                
                <Label Text="Kıble yönünü hesaplayabilmek için konumunuza ihtiyacımız var." 
                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>
                
                <Button Text="İzin Ver"
                        BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                        TextColor="{AppThemeBinding Light=White, Dark=Black}"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Clicked="OnRequestLocationPermission_Clicked"/>
            </VerticalStackLayout>
        </Border>
        </Grid>

        <!-- Genel İzin/Ayarlar Uyarısı - Overlay (DisplayAlert yerine) -->
        <Grid x:Name="PermissionOverlay"
              BackgroundColor="{AppThemeBinding Light=#DDFFFFFF, Dark=#DD000000}"
              IsVisible="False"
              ZIndex="101"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand">
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
                   Padding="20"
                   StrokeShape="RoundRectangle 20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="30"
                   Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   WidthRequest="300">
                <VerticalStackLayout Spacing="15">
                    <Label x:Name="PermissionOverlayTitle"
                           Text="İzin Gerekli"
                           FontAttributes="Bold"
                           FontSize="20"
                           TextColor="{AppThemeBinding Light=#00796B, Dark=#80CBC4}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="PermissionOverlayMessage"
                           Text="Kıble yönünü hesaplayabilmek için ayarlardan konum izni vermeniz gerekmektedir."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#424242, Dark=#EEEEEE}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center" Margin="0,10,0,0">
                        <Button x:Name="PermissionOverlayCancelButton"
                                Text="İptal"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                FontAttributes="Bold"
                                Clicked="OnPermissionOverlayCancel_Clicked"/>

                        <Button x:Name="PermissionOverlayConfirmButton"
                                Text="Ayarlara Git"
                                BackgroundColor="{AppThemeBinding Light=#00796B, Dark=#009688}"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                Padding="20,0"
                                Clicked="OnPermissionOverlayConfirm_Clicked"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>


    </Grid>

</ContentPage>

